{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node prebuild.mjs",
    "build": "npm run prebuild && node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "dev": "NODE_ENV=development npm run build && npm run start",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "4.18.2",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/node": "^20.10.0",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "typescript": "^5.3.0"
  }
}
